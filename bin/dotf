#!/bin/bash

set -e

SOURCE_PATH="${BASH_SOURCE[0]}"
while [ -L "$SOURCE_PATH" ]; do
    SOURCE_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
    SOURCE_PATH="$(readlink "$SOURCE_PATH")"
    case "$SOURCE_PATH" in
        /*) ;;
        *) SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH" ;;
    esac
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
DOTFILES_DIR="$(dirname "$SCRIPT_DIR")"
export DOTFILES_DIR
# shellcheck source=lib/dotf-common.sh
source "$SCRIPT_DIR/lib/dotf-common.sh"
LOGS_DIR="$DOTFILES_DIR/logs"
LOG_RETENTION=30
HOMEBREW_AUTO_UPDATE_SECS="${DOTF_HOMEBREW_AUTO_UPDATE_SECS:-604800}"

rotate_logs() {
    local retention="${1:-$LOG_RETENTION}"
    local logs=()
    local log_file

    [ -d "$LOGS_DIR" ] || return 0

    while IFS= read -r log_file; do
        [ -n "$log_file" ] && logs+=("$log_file")
    done < <(find "$LOGS_DIR" -maxdepth 1 -type f -name 'dotf_*.log' | sort -r)

    local index
    for ((index = retention; index < ${#logs[@]}; index++)); do
        rm -f -- "${logs[$index]}"
    done
}

DOTF_COMMANDS=(
    $'run\tSet up development environment from scratch'
    $'outdated\tShow managed package updates and write a Pi PR prompt'
    $'migrate\tRun one-time migrations for existing machines'
    $'steps\tList every setup step with its class name and description'
    $'help\tShow this help message'
)

# Initialize logging - create logs directory and set up log file
init_logging() {
    mkdir -p "$LOGS_DIR"
    rotate_logs $((LOG_RETENTION - 1))
    # Generate timestamp for log filename
    LOG_TIMESTAMP=$(dotf_date '%Y-%m-%d_%H-%M-%S')
    LOG_FILE="$LOGS_DIR/dotf_${LOG_TIMESTAMP}.log"
    export LOG_FILE
    : > "$LOG_FILE"
}

debug() {
    timestamp=$(dotf_date '%H:%M:%S.%3N' '%H:%M:%S')
    local message="[$timestamp] $1"

    # Always write to log file
    echo "$message" >> "$LOG_FILE"

    # Also output to STDOUT if DEBUG=true
    if [ "${DEBUG:-false}" = "true" ]; then
        echo "$message"
    fi
}

announce() {
    if command -v gum &> /dev/null; then
        gum style --bold --foreground 212 "$1"
    else
        echo "==> $1"
    fi
}

warn() {
    if command -v gum &> /dev/null; then
        gum style --foreground 214 "$1"
    else
        echo "$1"
    fi
}

render_tsv_table() {
    if command -v gum &> /dev/null; then
        gum table --separator $'\t' --border rounded --print
    else
        cat
    fi
}

ensure_homebrew_env() {
    if [ -x "$HOME/.homebrew/bin/brew" ]; then
        eval "$("$HOME/.homebrew/bin/brew" shellenv bash)"
    elif command -v brew &> /dev/null; then
        eval "$(brew shellenv bash)"
    elif [ -x /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv bash)"
    elif [ -x /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv bash)"
    fi
}

ensure_mise_env() {
    if [ -d "$HOME/.local/bin" ]; then
        export PATH="$HOME/.local/bin:$PATH"
    fi

    if command -v mise &> /dev/null; then
        eval "$(mise activate bash)"
    fi
}

managed_brew_formulae() {
    if [ -n "${DOTF_MANAGED_BREW_FORMULAE:-}" ]; then
        printf '%s\n' "$DOTF_MANAGED_BREW_FORMULAE" | tr ',' '\n' | awk '{$1=$1}; NF'
        return 0
    fi

    (
        cd "$DOTFILES_DIR"
        ruby -r ./lib/dotfiles.rb -e 'puts Dotfiles::Config.new(ENV.fetch("DOTFILES_DIR")).brew_packages'
    )
}

managed_brew_casks() {
    if [ -n "${DOTF_MANAGED_BREW_CASKS:-}" ]; then
        printf '%s\n' "$DOTF_MANAGED_BREW_CASKS" | tr ',' '\n' | awk '{$1=$1}; NF'
        return 0
    fi

    (
        cd "$DOTFILES_DIR"
        ruby -r ./lib/dotfiles.rb -e '
          config = Dotfiles::Config.new(ENV.fetch("DOTFILES_DIR"))
          puts((config.brew_casks + config.applications.map { |app| app["brew_cask"] }).compact.uniq)
        '
    )
}

is_debian() {
    [ "${DOTF_FORCE_NON_DEBIAN:-false}" = "true" ] && return 1
    [ "${DOTF_FORCE_DEBIAN:-false}" = "true" ] || [ -f /etc/debian_version ]
}

DOTF_LOCK_DIR="${DOTF_LOCK_DIR:-$HOME/.dotfiles.lock}"

acquire_dotf_lock() {
    if mkdir "$DOTF_LOCK_DIR" 2>/dev/null; then
        echo "$$" > "$DOTF_LOCK_DIR/pid"
        trap release_dotf_lock EXIT
        return 0
    fi

    local existing_pid
    existing_pid="$(cat "$DOTF_LOCK_DIR/pid" 2>/dev/null)" || true
    if [ -n "$existing_pid" ] && kill -0 "$existing_pid" 2>/dev/null; then
        echo "Error: another dotf instance is already running (PID $existing_pid, lock: $DOTF_LOCK_DIR). If stale, remove $DOTF_LOCK_DIR." >&2
        exit 1
    fi

    rm -rf "$DOTF_LOCK_DIR" 2>/dev/null || true
    if mkdir "$DOTF_LOCK_DIR" 2>/dev/null; then
        echo "$$" > "$DOTF_LOCK_DIR/pid"
        trap release_dotf_lock EXIT
        return 0
    fi

    echo "Error: could not acquire dotf lock at $DOTF_LOCK_DIR" >&2
    exit 1
}

release_dotf_lock() {
    rm -rf "$DOTF_LOCK_DIR" 2>/dev/null || true
}

cmd_run() {
    acquire_dotf_lock
    init_logging
    debug "Starting dotf run command"
    "$SCRIPT_DIR/bootstrap"
    ensure_homebrew_env
    ensure_mise_env

    cd "$DOTFILES_DIR"
    ruby -r ./lib/dotfiles.rb -e "Dotfiles::MigrationRunner.new('$LOG_FILE').run_if_existing_machine"
    ruby -r ./lib/dotfiles.rb -e "Dotfiles::Runner.new('$LOG_FILE').run"

    debug "Run complete"
}

report_mise_outdated() {
    announce "Checking mise tools"
    if ! command -v mise &> /dev/null; then
        warn "Skipping mise (mise not found on PATH)"
        return 0
    fi

    local output
    output="$(
        unset BUNDLE_GEMFILE BUNDLE_BIN_PATH RUBYOPT GEM_HOME GEM_PATH 2>/dev/null || true
        mise outdated --bump --json 2>/dev/null | ruby -rjson -e '
          begin
            tools = JSON.parse(STDIN.read)
          rescue JSON::ParserError
            tools = {}
          end
          if tools.empty?
            puts "mise tools are up to date"
          else
            puts "tool\tcurrent\tlatest"
            tools.each do |name, tool|
              current = tool["current"].to_s
              latest = tool["latest"].to_s
              next if current.empty? || latest.empty? || current == latest
              puts "#{name}\t#{current}\t#{latest}"
            end
          end
        '
    )"
    if [[ "$output" == $'tool\tcurrent\tlatest'* ]]; then
        printf '%s\n' "$output" | render_tsv_table
    else
        printf '%s\n' "$output"
    fi
}

report_pi_package_outdated() {
    announce "Checking Pi packages"

    local settings_path="$DOTFILES_DIR/files/home/.pi/agent/settings.json"
    if [ ! -f "$settings_path" ]; then
        warn "Skipping Pi packages (settings not found)"
        return 0
    fi

    if ! command -v mise &> /dev/null; then
        warn "Skipping Pi packages (mise not found on PATH)"
        return 0
    fi

    local output
    output="$(
        unset BUNDLE_GEMFILE BUNDLE_BIN_PATH RUBYOPT GEM_HOME GEM_PATH 2>/dev/null || true
        ruby -rjson -e '
          settings = JSON.parse(File.read(ARGV.fetch(0)))
          settings.fetch("packages", []).grep(/^npm:/).each do |source|
            match = source.match(/\Anpm:(.+)@([^@]+)\z/)
            next unless match
            puts [match[1], match[2]].join("\t")
          end
        ' "$settings_path" | while IFS=$'\t' read -r package current; do
            latest="$(mise exec node@lts -- npm view "$package" version 2>/dev/null || true)"
            [ -n "$latest" ] || continue
            [ "$current" = "$latest" ] && continue
            printf 'pi package\t%s\t%s\t%s\n' "$package" "$current" "$latest"
        done | ruby -e '
          rows = STDIN.read.lines.map(&:chomp).reject(&:empty?)
          if rows.empty?
            puts "Pi packages are up to date"
          else
            puts "manager\tpackage\tcurrent\tlatest"
            puts rows
          end
        '
    )"

    if [[ "$output" == $'manager\tpackage\tcurrent\tlatest'* ]]; then
        printf '%s\n' "$output" | render_tsv_table
    else
        printf '%s\n' "$output"
    fi
}

report_brew_outdated() {
    command -v brew &> /dev/null || return 0

    local managed_formulae managed_casks
    managed_formulae="$(managed_brew_formulae | paste -sd, -)"
    managed_casks="$(managed_brew_casks | paste -sd, -)"

    announce "Checking Homebrew formulae and casks"
    env HOMEBREW_AUTO_UPDATE_SECS="$HOMEBREW_AUTO_UPDATE_SECS" brew update-if-needed
    local output
    output="$(
        unset BUNDLE_GEMFILE BUNDLE_BIN_PATH RUBYOPT GEM_HOME GEM_PATH 2>/dev/null || true
        env HOMEBREW_NO_AUTO_UPDATE=1 brew outdated --json=v2 | env DOTF_MANAGED_FORMULAE="$managed_formulae" DOTF_MANAGED_CASKS="$managed_casks" ruby -rjson -e '
          managed_formulae = ENV.fetch("DOTF_MANAGED_FORMULAE", "").split(",")
          managed_casks = ENV.fetch("DOTF_MANAGED_CASKS", "").split(",")
          data = JSON.parse(STDIN.read)
          rows = []
          data.fetch("formulae", []).each do |formula|
            name = formula["name"]
            next unless managed_formulae.include?(name)
            rows << ["brew", name, Array(formula["installed_versions"]).join(", "), formula["current_version"]]
          end
          data.fetch("casks", []).each do |cask|
            name = cask["name"] || cask["token"]
            next unless managed_casks.include?(name)
            rows << ["brew cask", name, Array(cask["installed_versions"]).join(", "), cask["current_version"]]
          end
          if rows.empty?
            puts "Homebrew packages are up to date"
          else
            puts "manager\tpackage\tcurrent\tlatest"
            rows.each { |row| puts row.join("\t") }
          end
        '
    )"
    if [[ "$output" == $'manager\tpackage\tcurrent\tlatest'* ]]; then
        printf '%s\n' "$output" | render_tsv_table
    else
        printf '%s\n' "$output"
    fi
}

write_outdated_pi_prompt() {
    local prompt_dir="$DOTFILES_DIR/tmp"
    local prompt_path="$prompt_dir/pi-upgrade-prompt-$(dotf_date '%Y-%m-%d_%H-%M-%S').md"

    mkdir -p "$prompt_dir"
    cat > "$prompt_path" <<'EOF'
Update the pinned package versions in this dotfiles repository to the latest versions allowed by configured constraints.

Run `dotf outdated` first. Update files/home/.config/mise/config.toml, files/home/.pi/agent/settings.json, and any other pinned package-manager files as needed, run the relevant tests, then open a GitHub PR.
EOF

    warn "Wrote Pi upgrade prompt to $prompt_path"
    warn "You can run: pi \"\$(cat \"$prompt_path\")\""
}

cmd_outdated() {
    if [ $# -gt 0 ]; then
        echo "Error: dotf outdated does not accept options"
        return 1
    fi

    init_logging
    debug "Starting dotf outdated command"
    is_debian || ensure_homebrew_env
    ensure_mise_env

    report_mise_outdated
    report_pi_package_outdated
    if ! is_debian; then
        report_brew_outdated
    fi

    write_outdated_pi_prompt

    debug "Outdated check complete"
}

cmd_migrate() {
    acquire_dotf_lock
    init_logging
    debug "Starting dotf migrate command"
    ensure_homebrew_env
    ensure_mise_env

    cd "$DOTFILES_DIR"
    ruby -r ./lib/dotfiles.rb -e "Dotfiles::MigrationRunner.new('$LOG_FILE').run"

    debug "Migrate complete"
}

cmd_steps() {
    ensure_homebrew_env
    ensure_mise_env

    cd "$DOTFILES_DIR"
    ruby -r ./lib/dotfiles.rb -e "Dotfiles::Step.print_steps"
}

print_commands() {
    printf '%s\n' "${DOTF_COMMANDS[@]}"
}

cmd_help() {
    cat <<EOF
dotf - Dotfiles management tool

Usage: dotf <command> [options]

Commands:
EOF
    print_commands | while IFS=$'\t' read -r command description; do
        printf '  %-9s %s\n' "$command" "$description"
    done
    cat <<EOF

Logging:
  Logs are always written to logs/ directory with timestamped filenames.
  The latest 30 dotf logs are kept automatically.
  Set DEBUG=true to also output logs and subprocess output to the console.

Examples:
  dotf run                              # Initial setup
  dotf outdated                         # Show update candidates and write a Pi PR prompt
  dotf migrate                          # Run pending migrations on this machine
  DEBUG=true dotf run                   # Run with debug output to console
EOF
}

main() {
    rotate_logs

    if [ $# -eq 0 ]; then
        cmd_help
        exit 1
    fi

    case "$1" in
        run)
            cmd_run
            ;;
        outdated)
            shift
            cmd_outdated "$@"
            ;;
        migrate)
            cmd_migrate
            ;;
        steps)
            cmd_steps
            ;;
        help|--help|-h)
            cmd_help
            ;;
        __commands)
            print_commands
            ;;
        *)
            echo "Error: Unknown command '$1'"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
