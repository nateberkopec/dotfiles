#!/bin/bash

set -e

SOURCE_PATH="${BASH_SOURCE[0]}"
while [ -L "$SOURCE_PATH" ]; do
    SOURCE_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
    SOURCE_PATH="$(readlink "$SOURCE_PATH")"
    case "$SOURCE_PATH" in
        /*) ;;
        *) SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH" ;;
    esac
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
DOTFILES_DIR="$(dirname "$SCRIPT_DIR")"
export DOTFILES_DIR
# shellcheck source=lib/dotf-common.sh
source "$SCRIPT_DIR/lib/dotf-common.sh"
LOGS_DIR="$DOTFILES_DIR/logs"
LOG_RETENTION=30
PACKAGE_UPGRADE_DELAY="${DOTF_PACKAGE_UPGRADE_DELAY:-3d}"
HOMEBREW_AUTO_UPDATE_SECS="${DOTF_HOMEBREW_AUTO_UPDATE_SECS:-604800}"

rotate_logs() {
    local retention="${1:-$LOG_RETENTION}"
    local logs=()
    local log_file

    [ -d "$LOGS_DIR" ] || return 0

    while IFS= read -r log_file; do
        [ -n "$log_file" ] && logs+=("$log_file")
    done < <(find "$LOGS_DIR" -maxdepth 1 -type f -name 'dotf_*.log' | sort -r)

    local index
    for ((index = retention; index < ${#logs[@]}; index++)); do
        rm -f -- "${logs[$index]}"
    done
}

DOTF_COMMANDS=(
    $'run\tSet up development environment from scratch'
    $'upgrade\tRefresh and upgrade mise tools, system packages, Pi extensions, and Homebrew apps'
    $'outdated\tShow managed package updates that match configured constraints'
    $'migrate\tRun one-time migrations for existing machines'
    $'steps\tList every setup step with its class name and description'
    $'help\tShow this help message'
)

# Initialize logging - create logs directory and set up log file
init_logging() {
    mkdir -p "$LOGS_DIR"
    rotate_logs $((LOG_RETENTION - 1))
    # Generate timestamp for log filename
    LOG_TIMESTAMP=$(dotf_date '%Y-%m-%d_%H-%M-%S')
    LOG_FILE="$LOGS_DIR/dotf_${LOG_TIMESTAMP}.log"
    export LOG_FILE
    : > "$LOG_FILE"
}

debug() {
    timestamp=$(dotf_date '%H:%M:%S.%3N' '%H:%M:%S')
    local message="[$timestamp] $1"

    # Always write to log file
    echo "$message" >> "$LOG_FILE"

    # Also output to STDOUT if DEBUG=true
    if [ "${DEBUG:-false}" = "true" ]; then
        echo "$message"
    fi
}

announce() {
    if command -v gum &> /dev/null; then
        gum style --bold --foreground 212 "$1"
    else
        echo "==> $1"
    fi
}

warn() {
    if command -v gum &> /dev/null; then
        gum style --foreground 214 "$1"
    else
        echo "$1"
    fi
}

render_tsv_table() {
    if command -v gum &> /dev/null; then
        gum table --separator $'\t' --border rounded --print
    else
        cat
    fi
}

report_mise_updates() {
    announce "Checking for mise updates"
    (
        unset BUNDLE_GEMFILE BUNDLE_BIN_PATH RUBYOPT GEM_HOME GEM_PATH 2>/dev/null || true
        mise outdated --json 2>/dev/null | ruby -rjson -e '
            begin
              tools = JSON.parse(STDIN.read)
            rescue JSON::ParserError
              exit 0
            end
            semver = ->(v) { v.to_s.match?(/^v?\d+(?:\.\d+)*(?:[-+][0-9A-Za-z.-]+)?$/) }
            actionable = tools.select do |_name, t|
              semver.call(t["requested"]) && semver.call(t["current"]) && semver.call(t["latest"]) && t["current"] != t["latest"]
            end
            if actionable.empty?
              puts "mise tools are up to date"
            else
              puts "#{actionable.size} tool(s) have updates available:"
              actionable.each { |name, t| puts "  #{name}: #{t["current"]} -> #{t["latest"]}" }
            end
        '
    )
}

ensure_homebrew_env() {
    if [ -x "$HOME/.homebrew/bin/brew" ]; then
        eval "$("$HOME/.homebrew/bin/brew" shellenv bash)"
    elif command -v brew &> /dev/null; then
        eval "$(brew shellenv bash)"
    elif [ -x /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv bash)"
    elif [ -x /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv bash)"
    fi
}

ensure_mise_env() {
    if [ -d "$HOME/.local/bin" ]; then
        export PATH="$HOME/.local/bin:$PATH"
    fi

    if command -v mise &> /dev/null; then
        eval "$(mise activate bash)"
        hash -r
    fi

    configure_mise_package_managers
}

# mise's native brew backend also works on Linux (linuxbrew), so scope
# [bootstrap.packages] managers to the platform's package manager.
configure_mise_package_managers() {
    if is_debian; then
        export MISE_SYSTEM_PACKAGES_MANAGERS="apt"
    else
        export MISE_SYSTEM_PACKAGES_MANAGERS="brew"
    fi
}

user_has_admin_rights() {
    if [ -n "${DOTF_FORCE_ADMIN:-}" ]; then
        [ "$DOTF_FORCE_ADMIN" = "true" ]
        return
    fi
    id -Gn | tr ' ' '\n' | grep -qx admin
}

# Non-admin macOS uses a private Homebrew clone that mise's native brew
# backend can't target, so the packages phase is skipped there and the
# Non-Admin Brew Packages step installs them instead.
mise_packages_supported() {
    is_debian || user_has_admin_rights
}

run_mise_bootstrap() {
    announce "Converging machine with mise bootstrap"

    local skip=""
    if ! mise_packages_supported; then
        skip="packages"
    fi

    local args=(-C "$HOME" bootstrap --yes --update)
    if [ -n "$skip" ]; then
        args+=(--skip "$skip")
    fi

    set -o pipefail
    mise "${args[@]}" 2>&1 | tee -a "$LOG_FILE"
    local status=$?
    set +o pipefail
    return $status
}

is_debian() {
    [ "${DOTF_FORCE_NON_DEBIAN:-false}" = "true" ] && return 1
    [ "${DOTF_FORCE_DEBIAN:-false}" = "true" ] || [ -f /etc/debian_version ]
}

DOTF_LOCK_DIR="${DOTF_LOCK_DIR:-$HOME/.dotfiles.lock}"

acquire_dotf_lock() {
    if mkdir "$DOTF_LOCK_DIR" 2>/dev/null; then
        echo "$$" > "$DOTF_LOCK_DIR/pid"
        trap release_dotf_lock EXIT
        return 0
    fi

    local existing_pid
    existing_pid="$(cat "$DOTF_LOCK_DIR/pid" 2>/dev/null)" || true
    if [ -n "$existing_pid" ] && kill -0 "$existing_pid" 2>/dev/null; then
        echo "Error: another dotf instance is already running (PID $existing_pid, lock: $DOTF_LOCK_DIR). If stale, remove $DOTF_LOCK_DIR." >&2
        exit 1
    fi

    rm -rf "$DOTF_LOCK_DIR" 2>/dev/null || true
    if mkdir "$DOTF_LOCK_DIR" 2>/dev/null; then
        echo "$$" > "$DOTF_LOCK_DIR/pid"
        trap release_dotf_lock EXIT
        return 0
    fi

    echo "Error: could not acquire dotf lock at $DOTF_LOCK_DIR" >&2
    exit 1
}

release_dotf_lock() {
    rm -rf "$DOTF_LOCK_DIR" 2>/dev/null || true
}

cmd_run() {
    acquire_dotf_lock
    init_logging
    debug "Starting dotf run command"
    "$SCRIPT_DIR/bootstrap"
    ensure_homebrew_env
    ensure_mise_env

    run_mise_bootstrap
    ensure_mise_env

    cd "$DOTFILES_DIR"
    ruby -r ./lib/dotfiles.rb -e "Dotfiles::MigrationRunner.new('$LOG_FILE').run_if_existing_machine"
    ruby -r ./lib/dotfiles.rb -e "Dotfiles::Runner.new('$LOG_FILE').run"

    debug "Run complete"
}

cmd_upgrade() {
    acquire_dotf_lock
    init_logging
    debug "Starting dotf upgrade command"
    is_debian || ensure_homebrew_env
    ensure_mise_env

    if ! command -v mise &> /dev/null; then
        echo "Error: mise not found on PATH"
        return 1
    fi

    if ! mise_packages_supported && ! command -v brew &> /dev/null; then
        echo "Error: brew not found on PATH"
        return 1
    fi

    announce "Refreshing mise metadata"
    mise cache clear --yes
    mise plugins update
    report_mise_updates

    announce "Checking for mise updates older than $PACKAGE_UPGRADE_DELAY"
    mise up --dry-run --before "$PACKAGE_UPGRADE_DELAY" --yes

    announce "Upgrading mise tools older than $PACKAGE_UPGRADE_DELAY"
    mise up --before "$PACKAGE_UPGRADE_DELAY" --yes
    mise install --before "$PACKAGE_UPGRADE_DELAY" --yes

    if command -v pi &> /dev/null; then
        announce "Updating Pi extensions"
        pi update --extensions
    else
        warn "Skipping Pi extensions (pi not found on PATH)"
    fi

    announce "Pruning mise installs"
    mise prune --yes
    mise cache prune --yes

    if mise_packages_supported; then
        announce "Upgrading system packages"
        mise -C "$HOME" bootstrap packages upgrade --yes || warn "Skipping system packages (mise bootstrap packages upgrade failed)"
    else
        # Everything in the private non-admin Homebrew prefix is managed by
        # this repo, so a full upgrade is scoped to managed packages already.
        announce "Upgrading private Homebrew packages"
        env HOMEBREW_AUTO_UPDATE_SECS="$HOMEBREW_AUTO_UPDATE_SECS" brew update-if-needed
        env HOMEBREW_NO_AUTO_UPDATE=1 brew upgrade
        env HOMEBREW_NO_AUTO_UPDATE=1 brew cleanup
    fi

    debug "Upgrade complete"
}

report_mise_outdated() {
    announce "Checking mise tools"
    if ! command -v mise &> /dev/null; then
        warn "Skipping mise (mise not found on PATH)"
        return 0
    fi

    local output
    output="$(
        unset BUNDLE_GEMFILE BUNDLE_BIN_PATH RUBYOPT GEM_HOME GEM_PATH 2>/dev/null || true
        mise outdated --json 2>/dev/null | ruby -rjson -e '
          begin
            tools = JSON.parse(STDIN.read)
          rescue JSON::ParserError
            tools = {}
          end
          if tools.empty?
            puts "mise tools are up to date"
          else
            puts "tool\tcurrent\tlatest"
            tools.each do |name, tool|
              current = tool["current"].to_s
              latest = tool["latest"].to_s
              next if current.empty? || latest.empty? || current == latest
              puts "#{name}\t#{current}\t#{latest}"
            end
          end
        '
    )"
    if [[ "$output" == $'tool\tcurrent\tlatest'* ]]; then
        printf '%s\n' "$output" | render_tsv_table
    else
        printf '%s\n' "$output"
    fi
}

report_packages_outdated() {
    announce "Checking system packages"
    if mise_packages_supported; then
        mise -C "$HOME" bootstrap packages upgrade --dry-run || warn "Skipping system packages (mise bootstrap packages upgrade failed)"
    fi

    command -v brew &> /dev/null || return 0
    announce "Checking Homebrew casks"
    env HOMEBREW_AUTO_UPDATE_SECS="$HOMEBREW_AUTO_UPDATE_SECS" brew update-if-needed
    env HOMEBREW_NO_AUTO_UPDATE=1 brew outdated
}

write_outdated_pi_prompt() {
    local prompt_dir="$DOTFILES_DIR/tmp"
    local prompt_path="$prompt_dir/pi-upgrade-prompt-$(dotf_date '%Y-%m-%d_%H-%M-%S').md"

    mkdir -p "$prompt_dir"
    cat > "$prompt_path" <<'EOF'
Update the pinned package versions in this dotfiles repository to the latest versions allowed by configured constraints.

Run `dotf outdated` first. Update files/home/.config/mise/config.toml and any other pinned package-manager files as needed, run the relevant tests, then open a GitHub PR.
EOF

    warn "Wrote Pi upgrade prompt to $prompt_path"
    warn "You can run: pi \"\$(cat \"$prompt_path\")\""
}

cmd_outdated() {
    if [ $# -gt 0 ]; then
        echo "Error: dotf outdated does not accept options"
        return 1
    fi

    init_logging
    debug "Starting dotf outdated command"
    is_debian || ensure_homebrew_env
    ensure_mise_env

    report_mise_outdated
    report_packages_outdated

    write_outdated_pi_prompt

    debug "Outdated check complete"
}

cmd_migrate() {
    acquire_dotf_lock
    init_logging
    debug "Starting dotf migrate command"
    ensure_homebrew_env
    ensure_mise_env

    cd "$DOTFILES_DIR"
    ruby -r ./lib/dotfiles.rb -e "Dotfiles::MigrationRunner.new('$LOG_FILE').run"

    debug "Migrate complete"
}

cmd_steps() {
    ensure_homebrew_env
    ensure_mise_env

    cd "$DOTFILES_DIR"
    ruby -r ./lib/dotfiles.rb -e "Dotfiles::Step.print_steps"
}

print_commands() {
    printf '%s\n' "${DOTF_COMMANDS[@]}"
}

cmd_help() {
    cat <<EOF
dotf - Dotfiles management tool

Usage: dotf <command> [options]

Commands:
EOF
    print_commands | while IFS=$'\t' read -r command description; do
        printf '  %-9s %s\n' "$command" "$description"
    done
    cat <<EOF

Logging:
  Logs are always written to logs/ directory with timestamped filenames.
  The latest 30 dotf logs are kept automatically.
  Set DEBUG=true to also output logs and subprocess output to the console.

Examples:
  dotf run                              # Initial setup
  dotf upgrade                          # Upgrade mise tools, system packages, Pi extensions, and Homebrew apps
  dotf outdated                         # Show update candidates and write a Pi PR prompt
  dotf migrate                          # Run pending migrations on this machine
  DEBUG=true dotf run                   # Run with debug output to console
EOF
}

main() {
    rotate_logs

    if [ $# -eq 0 ]; then
        cmd_help
        exit 1
    fi

    case "$1" in
        run)
            cmd_run
            ;;
        upgrade)
            cmd_upgrade
            ;;
        outdated)
            shift
            cmd_outdated "$@"
            ;;
        migrate)
            cmd_migrate
            ;;
        steps)
            cmd_steps
            ;;
        help|--help|-h)
            cmd_help
            ;;
        __commands)
            print_commands
            ;;
        *)
            echo "Error: Unknown command '$1'"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
