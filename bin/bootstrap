#!/bin/bash

set -e

BOOTSTRAP_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_ROOT="$(dirname "$BOOTSTRAP_DIR")"
# shellcheck source=lib/dotf-common.sh
source "$BOOTSTRAP_DIR/lib/dotf-common.sh"

is_macos() {
    [ "$(uname -s)" = "Darwin" ]
}

is_linux() {
    [ "$(uname -s)" = "Linux" ]
}

debug() {
    if [ "${DEBUG:-false}" = "true" ]; then
        timestamp=$(dotf_date '%H:%M:%S.%3N' '%H:%M:%S')
        echo "[$timestamp] $1"
    fi
}

brew_quiet() {
    if [ "${DEBUG:-false}" = "true" ]; then
        HOMEBREW_NO_AUTO_UPDATE=1 brew "$@"
    else
        HOMEBREW_NO_AUTO_UPDATE=1 brew "$@" >/dev/null 2>&1
    fi
}

private_homebrew_prefix() {
    printf '%s\n' "$HOME/.homebrew"
}

private_homebrew_bin() {
    printf '%s\n' "$(private_homebrew_prefix)/bin/brew"
}

user_has_admin_rights() {
    id -Gn | tr ' ' '\n' | grep -qx admin
}

resolve_homebrew_bin() {
    if command -v brew &> /dev/null; then
        command -v brew
    elif [ -x /opt/homebrew/bin/brew ]; then
        printf '%s\n' "/opt/homebrew/bin/brew"
    elif [ -x /usr/local/bin/brew ]; then
        printf '%s\n' "/usr/local/bin/brew"
    fi
}

install_private_homebrew() {
    local prefix
    prefix="$(private_homebrew_prefix)"

    debug "Installing private Homebrew to ${prefix}..."
    mkdir -p "$(dirname "$prefix")"
    if [ -d "$prefix/.git" ]; then
        debug "Private Homebrew repository already present"
    else
        git clone --depth=1 https://github.com/Homebrew/brew "$prefix"
    fi
    mkdir -p "$prefix/Cellar" "$prefix/Caskroom" "$HOME/Library/Caches/Homebrew"
}

configure_homebrew_shellenv() {
    local brew_bin="$1"
    local zprofile_path="$HOME/.zprofile"
    local shellenv_line
    shellenv_line="$(printf 'eval \"$(%s shellenv)\"' "$brew_bin")"

    if ! grep -Fq "$shellenv_line" "$zprofile_path" 2>/dev/null; then
        printf '%s\n' "$shellenv_line" >> "$zprofile_path"
    fi

    eval "$("$brew_bin" shellenv -s bash)"
}

install_homebrew() {
    local install_script
    install_script="$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    if should_install_homebrew_noninteractively; then
        NONINTERACTIVE=1 /bin/bash -c "$install_script"
    else
        /bin/bash -c "$install_script"
    fi
}

should_install_homebrew_noninteractively() {
    [ -n "${CI:-}" ] || [ -n "${NONINTERACTIVE:-}" ] || ! has_terminal
}

has_terminal() {
    [ -t 0 ] && [ -t 1 ]
}

bootstrap_homebrew() {
    if ! is_macos; then
        return 0
    fi

    local brew_bin=""

    if user_has_admin_rights; then
        if ! command -v brew &> /dev/null; then
            debug "Installing Homebrew..."
            install_homebrew
        fi
        brew_bin="$(resolve_homebrew_bin)"
    else
        if [ ! -x "$(private_homebrew_bin)" ]; then
            install_private_homebrew
        fi
        brew_bin="$(private_homebrew_bin)"
    fi

    if [ -z "$brew_bin" ] || [ ! -x "$brew_bin" ]; then
        echo "Error: Homebrew installation completed but 'brew' was not found"
        exit 1
    fi

    configure_homebrew_shellenv "$brew_bin"
}

bootstrap_debian_prereqs() {
    if ! is_linux; then
        return 0
    fi

    debug "Installing Debian prerequisites..."
    sudo apt-get update -y
    sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y \
        ca-certificates \
        curl \
        git \
        gnupg \
        unzip \
        xz-utils

    bootstrap_debian_apt_sources
}

# APT sources that [bootstrap.packages] apt entries need before `mise
# bootstrap` installs packages. Desktop app sources that don't work in
# containers (1Password, Chrome) live in the Debian Desktop Apps step instead.
bootstrap_debian_apt_sources() {
    ensure_apt_source gierens \
        "deb [signed-by=/usr/share/keyrings/gierens-archive-keyring.gpg] http://deb.gierens.de stable main" \
        "https://raw.githubusercontent.com/eza-community/eza/main/deb.asc"
    ensure_apt_source mise \
        "deb [signed-by=/usr/share/keyrings/mise-archive-keyring.gpg] https://mise.jdx.dev/deb stable main" \
        "https://mise.jdx.dev/gpg-key.pub"
}

ensure_apt_source() {
    local name="$1" line="$2" key_url="$3"
    local list_path="/etc/apt/sources.list.d/${name}.list"
    local keyring_path="/usr/share/keyrings/${name}-archive-keyring.gpg"

    if [ ! -f "$keyring_path" ]; then
        debug "Installing APT keyring for ${name}..."
        curl -fsSL "$key_url" | sudo gpg --dearmor -o "$keyring_path"
    fi

    if [ ! -f "$list_path" ] || ! grep -Fqx "$line" "$list_path"; then
        debug "Installing APT source for ${name}..."
        printf '%s\n' "$line" | sudo tee "$list_path" >/dev/null
    fi
}

bootstrap_mise() {
    if ! command -v mise &> /dev/null; then
        debug "Installing mise..."
        if is_macos; then
            brew_quiet install mise
            hash -r
        else
            curl -fsSL https://mise.jdx.dev/install.sh | sh
            if [ -d "$HOME/.local/bin" ]; then
                export PATH="$HOME/.local/bin:$PATH"
            fi
        fi
    else
        debug "mise already installed"
    fi

    seed_global_mise_config

    # Trust mise config in current directory (needed for non-interactive environments)
    if [ -f ".mise.toml" ]; then
        debug "Trusting mise config..."
        if [ "${DEBUG:-false}" = "true" ]; then
            mise trust --yes || true
        else
            mise trust --yes 2>/dev/null || true
        fi
    fi

    # TODO: Remove this once mise 2026.8.0 makes precompiled Rubies the default.
    # test/bootstrap_test.rb intentionally fails after 2026-08-01 if this remains.
    export MISE_RUBY_COMPILE=false

    eval "$(mise activate bash)"
}

# The mise config's [dotfiles] sources and bootstrap hooks reference the repo
# as ~/.dotfiles; link it there when the checkout lives elsewhere (CI).
ensure_dotfiles_location() {
    [ "$DOTFILES_ROOT" = "$HOME/.dotfiles" ] && return 0
    [ -e "$HOME/.dotfiles" ] && return 0

    debug "Linking ~/.dotfiles to $DOTFILES_ROOT..."
    ln -s "$DOTFILES_ROOT" "$HOME/.dotfiles"
}

# `mise bootstrap` reads [bootstrap]/[dotfiles] from the global config, and
# the dotfiles phase keeps that file in sync afterwards. Seeding it here makes
# the current run converge against the repo's config, not last run's copy.
seed_global_mise_config() {
    debug "Seeding global mise config from the repo..."
    mkdir -p "$HOME/.config/mise"
    cp "$DOTFILES_ROOT/files/home/.config/mise/config.toml" "$HOME/.config/mise/config.toml"
}

main() {
    debug "Bootstrapping development environment..."

    ensure_dotfiles_location
    bootstrap_homebrew
    bootstrap_debian_prereqs
    bootstrap_mise

    debug "Bootstrap complete."
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
