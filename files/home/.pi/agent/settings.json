{
  "lastChangelogVersion": "0.62.0",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.4",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": false,
  "packages": [
    "npm:pi-mcp-adapter",
    "npm:pi-ding",
    "npm:pi-subagents",
    "npm:pi-web-providers"
  ],
  "npmCommand": [
    "mise",
    "exec",
    "node@lts",
    "--",
    "npm"
  ],
  "ding": {
    "enabled": true,
    "player": "afplay",
    "path": "/System/Library/Sounds/Glass.aiff"
  },
  "enabledModels": [
    "openai-codex/gpt-5.5",
    "anthropic/claude-opus-4-7"
  ],
  "subagents": {
    "agentOverrides": {
      "reviewer": {
        "model": "openai/gpt-5.5",
        "thinking": "xhigh"
      }
    }
  },
  "retry": {
    "enabled": true,
    "maxRetries": 5,
    "baseDelayMs": 2000,
    "maxDelayMs": 30000
  }
}
